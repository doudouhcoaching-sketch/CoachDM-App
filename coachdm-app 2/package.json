{
  "name": "coachdm-app",
  "version": "1.0.0",
  "private": true,
  "description": "Coach DM — App fitness & nutrition premium (web + mobile)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@coachdm/web",
    "dev:mobile": "turbo run dev --filter=@coachdm/mobile",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "supabase:start": "supabase start",
    "supabase:reset": "supabase db reset",
    "supabase:types": "supabase gen types typescript --local > packages/shared/src/database.types.ts"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.6.0",
    "prettier": "^3.3.3"
  },
  "packageManager": "[email protected]",
  "engines": {
    "node": ">=20.0.0"
  }
}
